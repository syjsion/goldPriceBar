<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <ApplicationIcon>Assets\AppIcon.ico</ApplicationIcon>
    <AssemblyName>GoldPriceBar</AssemblyName>
    <RootNamespace>GoldPriceBar.Windows</RootNamespace>
    <ImplicitUsings>disable</ImplicitUsings>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\GoldPriceBar.Core\GoldPriceBar.Core.csproj" />
    <Resource Include="..\..\Sources\goldPriceBar\Resources\FloatingCharacter\*.png">
      <Link>Assets\FloatingCharacter\%(Filename)%(Extension)</Link>
    </Resource>
    <Resource Include="Assets\AppIcon.ico" />
  </ItemGroup>
</Project>
