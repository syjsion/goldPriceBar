<Application x:Class="GoldPriceBar.Windows.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <SolidColorBrush x:Key="RiseBrush" Color="#F24038" />
        <SolidColorBrush x:Key="FallBrush" Color="#34C759" />
        <SolidColorBrush x:Key="GoldBrush" Color="#FFD600" />
    </Application.Resources>
</Application>
